# ============================================================
# Telegram Amazon Affiliate Bot — Environment Configuration
# Copy this file to .env and fill in your real values.
# ============================================================

# --- Telegram Bot (from @BotFather) ---
BOT_TOKEN=your_bot_token_here

# --- Telegram API Credentials (from https://my.telegram.org/apps) ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# --- Telegram Phone (for userbot session file) ---
# Used by scripts/generate_session.py to auto-fill phone number
TELEGRAM_PHONE=+911234567890

# --- Admin Telegram ID (your Telegram user ID) ---
ADMIN_TELEGRAM_ID=123456789

# --- PostgreSQL (alwaysdata) ---
# URL-encode special chars in password: @ -> %40, # -> %23, etc.
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Example: postgresql+asyncpg://achal:Aman%404899@postgresql-achal.alwaysdata.net:5432/achal_affiliate
DATABASE_URL=postgresql+asyncpg://user:password@postgresql-your_account.alwaysdata.net:5432/your_db_name

# --- Default Amazon Affiliate ---
DEFAULT_AFFILIATE_TAG=yourtag-21
DEFAULT_AMAZON_DOMAIN=amazon.in

# --- Channels (optional — can also be set via bot commands) ---
# SOURCE_CHANNELS=channel1,channel2
# DEST_CHANNEL_ID=-1001234567890
# DEST_CHANNEL_USERNAME=your_channel

# --- Duplicate Detection ---
# Same ASIN re-posted after this many hours is allowed (default: 1)
# DUPLICATE_WINDOW_HOURS=1

# --- Logging ---
LOG_LEVEL=INFO
